{
  "name": "tomato-timer",
  "version": "1.0.0",
  "description": "一个简约的番茄时钟桌面程序（macOS 风格）",
  "main": "main.js",
  "scripts": {
    "start": "electron ."
  },
  "keywords": ["pomodoro", "timer", "electron", "desktop"],
  "author": "Tomato Timer",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.tomatotimer.app",
    "productName": "TomatoTimer",
    "directories": {
      "output": "dist-app"
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "mac": {
      "target": ["dmg", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  }
}
